# ── Hugging Face ──────────────────────────────────────────────────────────────
HF_ACCESS_TOKEN=your_hf_access_token_here

# ── Azure Storage ─────────────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT=aitokenoptimizer1234
AZURE_STORAGE_KEY=your_storage_key_here
AZURE_CONTAINER=pipeline-data
AZURE_RESOURCE_GROUP=ai-token-optimizer-rg
AZURE_LOCATION=centralindia

# ── Azure Container Registry (for FastAPI image) ──────────────────────────────
AZURE_ACR_NAME=aitokenoptimizeracr
AZURE_ACR_PASSWORD=your_acr_password_here

# ── Azure Container Apps (FastAPI deployment) ─────────────────────────────────
AZURE_CONTAINER_APP=token-optimizer-api
AZURE_CONTAINER_ENV=token-optimizer-env
# Set to your Container Apps URL after running deploy_azure.sh:
API_URL=http://127.0.0.1:8000

# ── Azure Databricks (Spark pipeline) ────────────────────────────────────────
# Filled in automatically by azure_setup.sh:
DATABRICKS_WORKSPACE_URL=https://adb-xxxx.azuredatabricks.net
DATABRICKS_CLUSTER_ID=xxxx-xxxxxx-xxxxxxxx

# ── Elasticsearch + Kibana (Azure Container Instances) ────────────────────────
# Filled in after running: bash cloud/aci_elk_setup.sh
ES_HOST=http://localhost:9200
KIBANA_URL=http://localhost:5601